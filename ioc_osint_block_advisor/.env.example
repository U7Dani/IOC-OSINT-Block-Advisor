# Copia este archivo como .env y rellena solo las claves que tengas.
# Ninguna de estas variables es obligatoria: si falta una clave, la fuente
# correspondiente se marca como "no configurada" (skipped) y la herramienta
# sigue funcionando con el resto de señales (contexto + reglas locales).
#
# IMPORTANTE: nunca subas un .env con claves reales al repositorio.
# OSINT externo permanece deshabilitado por defecto en la aplicación,
# independientemente de que estas claves estén configuradas o no.
#
# Este fichero debe mantenerse en paralelo al .env.example de la raíz del
# repositorio (ambas ubicaciones son válidas para python-dotenv según desde
# dónde se ejecute la aplicación).

# VirusTotal (dominios, URLs, hashes, IPs)
VT_API_KEY=

# AbuseIPDB (reputación de IPs)
ABUSEIPDB_API_KEY=

# AlienVault OTX (dominios, URLs, IPs, hashes)
OTX_API_KEY=

# urlscan.io (solo se consulta si el usuario activa explícitamente
# "Incluir URL completa en OSINT" en la interfaz)
URLSCAN_API_KEY=
URLSCAN_AUTO_SUBMIT=false

# PhishTank no requiere API key para consultas básicas; se deja aquí
# preparado por si en el futuro se usa una key de aplicación registrada.
PHISHTANK_API_KEY=

# --- Integración BBOT (opcional) --------------------------------------
# BBOT (https://github.com/blacklanternsecurity/bbot) es una herramienta
# externa (AGPLv3) opcional: la aplicación funciona sin ella. Estas claves
# solo son usadas por los módulos de BBOT que decidas activar; ninguna se
# lee ni se guarda en ioc_osint_block_advisor/config/bbot_settings.json.
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
SECURITYTRAILS_API_KEY=
BINARYEDGE_API_KEY=
GITHUB_TOKEN=
BEVIGIL_API_KEY=
C99_API_KEY=
FULLHUNT_API_KEY=
HUNTERIO_API_KEY=
INTELX_API_KEY=
LEAKIX_API_KEY=
PASSIVETOTAL_USERNAME=
PASSIVETOTAL_API_KEY=
ZOOMEYE_API_KEY=
